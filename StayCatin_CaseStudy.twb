              <flipboard active-id='8' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Del Mar Ocean View leads all earners at $2.68M — beachfront + high min-nights = max revenue' captured-sheet='Top 10 Earners' id='1' />
                  <story-point caption='The $301–500 price range earns the most — not the most expensive tier' captured-sheet='Price vs Earnings' id='2' />
                  <story-point caption='Pacific Beach, Mission Beach &amp; La Jolla dominate — shore location is a major earnings driver' captured-sheet='Shore vs Inland Earnings' id='3' />
                  <story-point caption='Budget listings get more reviews, but ratings stay 94–96 across all price points' captured-sheet='Price vs Reviews' id='4' />
                  <story-point caption='&quot;Entire home/apt dominates with 8,304 listings — 70% of all properties' captured-sheet='Maximum listing based on Room Type' id='5' />
                  <story-point caption='Michael leads host earnings at $515K — moderate pricing + high bookings wins' captured-sheet='Top 3 Earners (Host Name)' id='6' />
                  <story-point caption='No strong link between price and earnings — outliers exist at both ends' captured-sheet='Price VS Earnings' id='7' />
                  <story-point caption='Entire home/apt holds 83% of all beds — guests prefer private full spaces' captured-sheet='Beds in Room Types' id='8' />
                  <story-point caption='Prices peak in July ($334) &amp; August ($317) — only 2 months cross the $300 mark' captured-sheet='Peaks' id='9' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
