        <calculation class='tableau' formula='IF CONTAINS(LOWER([NEIGHBOURHOOD]), &quot;beach&quot;)&#13;&#10;OR CONTAINS(LOWER([NEIGHBOURHOOD]), &quot;ocean&quot;)&#13;&#10;OR CONTAINS(LOWER([NEIGHBOURHOOD]), &quot;bay&quot;)&#13;&#10;OR CONTAINS(LOWER([NEIGHBOURHOOD]), &quot;la jolla&quot;)&#13;&#10;OR CONTAINS(LOWER([NEIGHBOURHOOD]), &quot;del mar&quot;)&#13;&#10;OR CONTAINS(LOWER([NEIGHBOURHOOD]), &quot;marina&quot;)&#13;&#10;THEN &quot;Shore&quot;&#13;&#10;ELSE &quot;Inland&quot;&#13;&#10;END' />
